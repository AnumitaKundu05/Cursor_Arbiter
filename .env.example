# Copy this file to .env and fill in. NEVER commit .env.
# .env is gitignored; .env.example is not.

# Required: your Anthropic API key.
ANTHROPIC_API_KEY=sk-ant-REPLACE_ME

# Optional: which Claude model the arbiter calls.
# Default if unset: claude-opus-4-5
ARBITER_MODEL=claude-opus-4-5

# Optional: model used by the "baseline" in benchmark/run_benchmark.py.
# Default if unset: same as ARBITER_MODEL.
BASELINE_MODEL=claude-opus-4-5
